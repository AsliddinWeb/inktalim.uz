# ==============================================================
# .env.example — muhit o'zgaruvchilari namunasi
# Bu faylni nusxalab .env nomini bering va qiymatlarni to'ldiring
# ==============================================================

# PostgreSQL sozlamalari
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mini_udemy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# To'liq DB ulanish URL (async driver ishlatiladi)
DATABASE_URL=postgresql+asyncpg://postgres:your_strong_password_here@db:5432/mini_udemy

# JWT token uchun maxfiy kalit (kamida 32 ta belgi, tasodifiy string ishlating)
SECRET_KEY=your-very-secret-key-change-this-in-production-32chars

# JWT algoritmi
ALGORITHM=HS256

# Access token amal qilish muddati (daqiqalarda)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ilova muhiti
ENVIRONMENT=production

# CORS — frontend domenlari (vergul bilan ajratilib yoziladi)
ALLOWED_ORIGINS=https://inktalim.asliddin.me,https://www.inktalim.asliddin.me,https://inktalim.uz,https://www.inktalim.uz

# Frontend URL (asosiy domen)
FRONTEND_URL=https://inktalim.uz

# Media fayllar papkasi
MEDIA_DIR=media

# Frontend — Vite muhit o'zgaruvchisi
# Nisbiy yo'l ishlating — ikkala domenga ham ishlaydi
VITE_API_URL=/api/v1
